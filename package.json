{
  "name": "embark",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "git submodule update --init --recursive && git config submodule.recurse true",
    "prepare": "husky",
    "postinstall": "husky",
    "test": "bun test --coverage scripts/__tests__",
    "utils": "bun scripts/utils.ts",
    "setup": "bun scripts/setup.ts",
    "studyChallenges": "bun run --filter @embark/learning dev",
    "portifolio": "bun run --filter @embark/portifolio dev"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/bun": "^1.3.9",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.9"
}
